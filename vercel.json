{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/((?!api/|@|src/|node_modules/|.*\\.).*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(bot|facebook|whatsapp|linkedin|twitter|slack|telegram|discord).*"
        }
      ],
      "destination": "/api/MetaInfo-og"
    },
    {
      "source": "/((?!api/|@|src/|node_modules/|.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}